# Docker container name (or ID) of your Satisfactory dedicated server.
# Find it with: docker ps --format '{{.Names}}'
CONTAINER_NAME=satisfactory-server

# ntfy topic URL to post join/leave notifications to.
# https://ntfy.sh/your-topic-here for the public service, or your own
# self-hosted ntfy instance.
NTFY_URL=https://ntfy.sh/your-topic-here

# Optional: title shown on the notification.
#NTFY_TITLE=Satisfactory

# Optional: bearer token, only needed if your ntfy topic requires auth.
#NTFY_TOKEN=
